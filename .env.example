# Database Configuration
# Supabase PostgreSQL connection (recommended for production)
# Add connection pooling parameters for optimal performance:
# - connection_limit: Max connections (recommended: 10-20)
# - pool_timeout: Connection wait timeout in seconds (recommended: 20)
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?connection_limit=10&pool_timeout=20"

# For development with local PostgreSQL:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/workscape_atlas_dev?connection_limit=5&pool_timeout=10"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon-key]"
SUPABASE_SERVICE_ROLE_KEY="[service-role-key]"

# NextAuth.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# OAuth Providers (Optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# Email Configuration (for contact forms and notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@workscapeatlas.com"

# File Upload Configuration
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=""

# Application Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Workscape Atlas"

# Redis (for caching, optional)
REDIS_URL=""

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE="100"

# API Keys for integrations
OPENAI_API_KEY=""

# Data Scraping Configuration
GOOGLE_PLACES_API_KEY=""
GOOGLE_MAPS_API_KEY=""

# Web Scraping Settings
SCRAPER_USER_AGENT="Mozilla/5.0 (compatible; WorkspaceAtlas/1.0; +https://workspaceatlas.com)"
SCRAPER_DELAY_MS="1000"
SCRAPER_MAX_RETRIES="3"
SCRAPER_TIMEOUT_MS="30000"

# Data Processing
IMAGE_UPLOAD_MAX_SIZE_MB="10"
IMAGE_QUALITY="80"
MAX_IMAGES_PER_WORKSPACE="20"

# JWT Configuration
JWT_SECRET="your-jwt-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Logging Configuration
LOG_LEVEL="INFO"
ENABLE_REQUEST_LOGGING="true"
# Demo admin access (cookie gate for /admin while DB auth is unprovisioned)
ADMIN_DEMO_KEY="set-a-demo-key"
